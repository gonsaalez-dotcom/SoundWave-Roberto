<div class="row">
  <div class="col-md-8 col-lg-6 mx-auto">
    <div class="mb-3">
      <a href="/artista/{{artista.id}}" class="btn btn-sm btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i>Volver al Artista
      </a>
    </div>

    <!-- Tarjeta del Formulario -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-dark text-white py-3">
        <h4 class="card-title mb-0 fw-bold text-center">
          <i class="fas fa-plus-circle text-success me-2"></i>Agregar Nueva Canción
        </h4>
      </div>
      
      <div class="card-body p-4">
        <div class="alert alert-secondary py-2 px-3 mb-4 d-flex align-items-center justify-content-between">
          <span class="text-muted"><i class="fas fa-user-tag me-2"></i>Artista asociado:</span>
          <span class="fw-bold text-dark fs-5">{{artista.nombre}}</span>
        </div>

        <form action="/artista/{{artista.id}}/cancion" method="POST">
          
          <div class="mb-3">
            <label for="titulo" class="form-label fw-bold">Título de la Canción</label>
            <div class="input-group">
              <span class="input-group-text bg-light"><i class="fas fa-heading text-muted"></i></span>
              <input 
                type="text" 
                class="form-control" 
                id="titulo" 
                name="titulo" 
                placeholder="Ej. Yesterday, Hips Don't Lie, Get Lucky" 
                required
              />
            </div>
          </div>
          
          <div class="mb-3">
            <label for="album" class="form-label fw-bold">Álbum</label>
            <div class="input-group">
              <span class="input-group-text bg-light"><i class="fas fa-compact-disc text-muted"></i></span>
              <input 
                type="text" 
                class="form-control" 
                id="album" 
                name="album" 
                placeholder="Ej. Help!, Oral Fixation Vol. 2, Random Access Memories" 
                required
              />
            </div>
          </div>
          
          <div class="mb-4">
            <label for="duracion" class="form-label fw-bold">Duración (en segundos)</label>
            <div class="input-group">
              <span class="input-group-text bg-light"><i class="fas fa-clock text-muted"></i></span>
              <input 
                type="number" 
                class="form-control" 
                id="duracion" 
                name="duracion" 
                min="1" 
                placeholder="Ej. 240 (equivale a 4 minutos)" 
                required
              />
            </div>
            <div class="form-text">Introduce el valor total en segundos. Ejemplos: 180 (3m 00s), 215 (3m 35s).</div>
          </div>
          
          <div class="d-flex gap-2 justify-content-end border-top pt-3">
            <a href="/artista/{{artista.id}}" class="btn btn-outline-secondary px-4">
              Cancelar
            </a>
            <button type="submit" class="btn btn-success px-4">
              <i class="fas fa-save me-1"></i>Guardar Canción
            </button>
          </div>
          
        </form>
      </div>
    </div>
  </div>
</div>
