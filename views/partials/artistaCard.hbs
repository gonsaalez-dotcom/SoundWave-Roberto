<div class="card h-100 shadow-sm border-0">
  <div class="card-body d-flex flex-column">
    <!-- Título y Número de canciones -->
    <div class="d-flex justify-content-between align-items-start mb-2">
      <h5 class="card-title fw-bold text-dark mb-0">{{nombre}}</h5>
      <span class="badge bg-primary rounded-pill" title="Cantidad de canciones">
        <i class="fas fa-music me-1"></i>{{#if canciones}}{{canciones.length}}{{else}}0{{/if}}
      </span>
    </div>
    
    <!-- Género y País -->
    <div class="mb-4">
      <span class="badge bg-secondary me-1">
        <i class="fas fa-tags me-1"></i>{{genero}}
      </span>
      <span class="badge bg-light text-dark border">
        <i class="fas fa-globe-americas me-1 text-muted"></i>{{pais}}
      </span>
    </div>

    <!-- Botones de Acción -->
    <div class="mt-auto pt-3 border-top d-flex gap-2 justify-content-between align-items-center">
      <a href="/artista/{{id}}" class="btn btn-sm btn-outline-primary flex-grow-1">
        <i class="fas fa-info-circle me-1"></i>Ver detalles
      </a>
      <a href="/artista/{{id}}/editar" class="btn btn-sm btn-outline-warning" title="Editar Artista">
        <i class="fas fa-edit"></i>
      </a>
      <form action="/artista/{{id}}/eliminar" method="POST" class="d-inline m-0" onsubmit="return confirm('¿Estás seguro de que deseas eliminar al artista {{nombre}} y todas sus canciones?');">
        <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar Artista">
          <i class="fas fa-trash-alt"></i>
        </button>
      </form>
    </div>
  </div>
</div>
