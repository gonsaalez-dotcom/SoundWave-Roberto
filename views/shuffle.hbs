<div class="row">
  <div class="col-md-8 col-lg-6 mx-auto text-center">
    
    {{#if cancion}}
      <!-- Tarjeta del Formulario Estilo Premium (Modo Oscuro) -->
      <div class="card border-0 shadow-lg mb-4 p-2" style="background-color: #121212; border: 1px solid #282828 !important; border-radius: 20px;">
        <div class="card-body p-4">
          
          <!-- Indicador de Modo Shuffle Activo -->
          <div class="d-flex align-items-center justify-content-center gap-2 mb-4">
            <span class="badge py-2 px-3 d-flex align-items-center gap-2" style="background: rgba(29, 185, 84, 0.1); color: #1db954; border-radius: 50px; font-size: 0.8rem;">
              <i class="fas fa-random pulse-icon"></i> MODO ALEATORIO
            </span>
          </div>

          <!-- Contenedor del Disco/Cover de la Canción con Brillo -->
          <div class="d-flex justify-content-center mb-4">
            <div class="rounded-4 d-flex align-items-center justify-content-center shadow-lg" 
                 style="width: 180px; height: 180px; background: linear-gradient(135deg, #282828 0%, #0b0b0d 100%); border: 2px solid rgba(255, 255, 255, 0.05); position: relative; overflow: hidden;">
              
              {{#if cancion.artista.imagenFondo}}
                <div class="position-absolute top-0 start-0 w-100 h-100 opacity-20" style="background: url('{{cancion.artista.imagenFondo}}') center/cover no-repeat;"></div>
              {{/if}}

              <!-- Icono de Música con Efecto de Rotación -->
              <i class="fas fa-compact-disc fa-4x text-success opacity-75 girar-disco" style="color: #1db954 !important; filter: drop-shadow(0 0 15px rgba(29, 185, 84, 0.4));"></i>
            </div>
          </div>

          <!-- Información del Tema -->
          <h3 class="fw-bold text-white mb-1" style="font-size: 1.4rem;">{{cancion.titulo}}</h3>
          
          <h5 class="mb-3" style="font-size: 1rem;">
            <a href="/artista/{{cancion.artista.id}}" class="text-decoration-none fw-bold" style="color: #1db954;">
              <i class="fas fa-user-circle me-1"></i>{{cancion.artista.nombre}}
            </a>
          </h5>
          
          <p class="small mb-4" style="color: #b3b3b3;">
            Álbum: <span class="text-white fw-bold">{{cancion.album}}</span>
          </p>

          <!-- Datos de la canción adaptados con insignias oscuras -->
          <div class="d-flex justify-content-center gap-2 mb-4">
            <span class="badge border-0 rounded-pill py-2 px-3 shadow-sm" style="background-color: #181818; color: #1db954;">
              <i class="fas fa-play me-1"></i>
              <!-- Mantiene la clase e ID para asegurar que funcione con tu javascript -->
              <span id="plays-{{cancion.id}}" class="play-counter-{{cancion.id}} fw-bold">{{cancion.reproducciones}}</span>
            </span>
            <span class="badge border-0 rounded-pill py-2 px-3 shadow-sm" style="background-color: #181818; color: #b3b3b3;">
              <i class="fas fa-clock me-1" style="color: #1db954;"></i>
              <span class="duration-formatter" data-seconds="{{cancion.duracion}}">{{cancion.duracion}} seg</span>
            </span>
          </div>

          <!-- Botones de Acción Estilizados -->
          <div class="d-flex justify-content-center gap-2">
            <!-- Botón Reproducir con doble data-id por seguridad con tus scripts -->
            <button class="btn btn-success btn-reproducir px-4 btn-premium-play" data-id="{{cancion.id}}" data-cancion-id="{{cancion.id}}" style="background-color: #1db954; border: none; border-radius: 50px; font-weight: bold;">
              <i class="fas fa-play me-1"></i>Reproducir
            </button>
            
            <a href="/shuffle" class="btn btn-outline-light px-4" style="border-radius: 50px; background: rgba(255,255,255,0.05); border: none; color: #b3b3b3;">
              <i class="fas fa-forward me-1"></i>Siguiente
            </a>
          </div>
        </div>
      </div>
      
    {{else}}
      <!-- Vista de Estado Vacío en Modo Oscuro -->
      <div class="card border-0 shadow-lg py-5 px-4" style="background-color: #121212; border: 1px solid #282828 !important; border-radius: 20px;">
        <div class="card-body" style="color: #b3b3b3;">
          <i class="fas fa-music fa-4x mb-3 opacity-30"></i>
          <h4 class="fw-bold text-white mb-2">¡Tu biblioteca de música está vacía!</h4>
          <p class="mb-4" style="color: #a7a7a7;">Para poder reproducir música en modo aleatorio (Shuffle), primero debes registrar artistas y agregarles canciones.</p>
          <div class="d-flex justify-content-center gap-2">
            <a href="/artista/nuevo" class="btn text-white btn-sm px-4 py-2" style="background-color: #1db954; border-radius: 50px; font-weight: bold;">
              <i class="fas fa-user-plus me-1"></i>Registrar Artista
            </a>
            <a href="/" class="btn btn-sm px-4 py-2" style="background: rgba(255,255,255,0.05); border: none; border-radius: 50px; color: #b3b3b3;">
              <i class="fas fa-home me-1"></i>Volver al Inicio
            </a>
          </div>
        </div>
      </div>
    {{/if}}

    <!-- Enlace de navegación inferior -->
    <div class="mt-3">
      <a href="/" class="btn btn-link text-decoration-none btn-link-volver" style="color: #b3b3b3;">
        <i class="fas fa-home me-1"></i>Volver al inicio
      </a>
    </div>

  </div>
</div>

<!-- Animaciones CSS exclusivas para el reproductor aleatorio -->
<style>
  .btn-premium-play:hover {
    background-color: #1ed760 !important;
    transform: scale(1.04);
    transition: all 0.2s ease;
  }
  .btn-link-volver:hover {
    color: #1db954 !important;
    transition: color 0.2s ease;
  }
  .girar-disco {
    animation: spin 25s linear infinite;
  }
  @keyframes spin {
    100% { transform: rotate(360deg); }
  }
  .pulse-icon {
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0% { opacity: 0.6; }
    50% { opacity: 1; }
    100% { opacity: 0.6; }
  }
</style>

<script src="/js/shuffle.js"></script>
